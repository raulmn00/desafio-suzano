# ─────────────────────────────────────────────────────────────
# Banco de dados (PostgreSQL)
# ─────────────────────────────────────────────────────────────
# Local (Docker Compose): host=localhost
DATABASE_URL="postgresql://ovgs:ovgs@localhost:5432/ovgs?schema=public"
# Em produção (Neon), use a connection string POOLED (-pooler) em DATABASE_URL:
#   postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/ovgs?sslmode=require&pgbouncer=true&connection_limit=1
# e a connection string DIRETA (sem -pooler) em DIRECT_URL para migrations:
DIRECT_URL="postgresql://ovgs:ovgs@localhost:5432/ovgs?schema=public"

# ─────────────────────────────────────────────────────────────
# Autenticação (JWT)
# ─────────────────────────────────────────────────────────────
# Em produção, gere um segredo forte e único (>= 32 chars), ex.:
#   openssl rand -base64 48
# A aplicação RECUSA subir com este valor padrão quando NODE_ENV=production.
JWT_SECRET="troque-este-segredo-em-producao"
JWT_EXPIRES_IN="1d"

# Credenciais semeadas (prisma/seed.ts)
SEED_OPERADOR_EMAIL="operador@ovgs.dev"
SEED_OPERADOR_SENHA="operador123"
SEED_AUDITOR_EMAIL="auditor@ovgs.dev"
SEED_AUDITOR_SENHA="auditor123"

# ─────────────────────────────────────────────────────────────
# Aplicação
# ─────────────────────────────────────────────────────────────
PORT=8080
# Origens permitidas para CORS (separadas por vírgula). '*' libera tudo (apenas dev).
CORS_ORIGINS="*"
NODE_ENV="development"
