# ─────────────────────────────────────────────────────────────
# Banco de dados (PostgreSQL)
# ─────────────────────────────────────────────────────────────
# Local (Docker Compose): host=localhost
DATABASE_URL="postgresql://ovgs:ovgs@localhost:5432/ovgs?schema=public"
# Em produção (Neon), use a connection string POOLED (-pooler) em DATABASE_URL:
#   postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/ovgs?sslmode=require&pgbouncer=true&connection_limit=1
# e a connection string DIRETA (sem -pooler) em DIRECT_URL para migrations:
DIRECT_URL="postgresql://ovgs:ovgs@localhost:5432/ovgs?schema=public"

# ─────────────────────────────────────────────────────────────
# Autenticação (JWT)
# ─────────────────────────────────────────────────────────────
# Em produção, gere um segredo forte e único (>= 32 chars), ex.:
#   openssl rand -base64 48
# A aplicação RECUSA subir com este valor padrão quando NODE_ENV=production.
JWT_SECRET="troque-este-segredo-em-producao"
# Access token curto (revogável via denylist) + refresh token rotacionado (single-use).
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Credenciais semeadas (prisma/seed.ts)
SEED_OPERADOR_EMAIL="operador@ovgs.dev"
SEED_OPERADOR_SENHA="operador123"
SEED_AUDITOR_EMAIL="auditor@ovgs.dev"
SEED_AUDITOR_SENHA="auditor123"

# ─────────────────────────────────────────────────────────────
# Aplicação
# ─────────────────────────────────────────────────────────────
PORT=8080
# Origens permitidas para CORS (separadas por vírgula). '*' libera tudo (apenas dev).
CORS_ORIGINS="*"
NODE_ENV="development"
# Nível dos logs estruturados (pino): trace|debug|info|warn|error|silent.
LOG_LEVEL="info"
# TTL do cache dos catálogos, em ms (padrão 30s).
CACHE_TTL_MS="30000"
# Cache distribuído: se definido, usa Redis; se vazio, cache in-memory (dev/test).
#   ex.: redis://localhost:6379  ·  rediss://default:senha@host.upstash.io:6379
REDIS_URL=""

# ─────────────────────────────────────────────────────────────
# Rate limiting (hardening HTTP)
# ─────────────────────────────────────────────────────────────
# Limite GLOBAL por IP (coarse anti-DoS): janela em ms + teto de requisições.
# O endpoint POST /auth/login tem um teto próprio e mais estrito (10/min, anti
# brute-force). Armazenamento in-memory por instância.
THROTTLE_TTL="60000"
THROTTLE_LIMIT="300"

# ─────────────────────────────────────────────────────────────
# Observabilidade — Sentry (error tracking)
# ─────────────────────────────────────────────────────────────
# Sem SENTRY_DSN o Sentry fica DESATIVADO (no-op). Em produção, o DSN vem do
# Secret Manager. Captura erros 5xx + não-tratados.
SENTRY_DSN=""
# Amostragem de tracing de performance (0 = só erros).
SENTRY_TRACES_SAMPLE_RATE="0"
